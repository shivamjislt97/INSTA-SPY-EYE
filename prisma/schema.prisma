generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model dp_history {
  id          Int      @id @default(autoincrement())
  imageUrl    String
  localPath   String
  imageHash   String
  capturedAt  DateTime @default(now())
  isChange    Boolean  @default(true)
}

model bot_state {
  id            Int      @id
  lastHash      String?
  lastCheckedAt DateTime?
}
